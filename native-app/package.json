{
  "name": "native-app",
  "version": "1.0.0",
  "main": "expo-router/entry",
  "scripts": {
    "start": "expo start",
    "start:clear": "expo start --clear",
    "start:tunnel": "expo start --tunnel",
    "android": "expo run:android",
    "android:release": "expo run:android --variant release",
    "android:device": "expo run:android --device",
    "ios": "expo run:ios",
    "ios:device": "expo run:ios --device",
    "ios:simulator": "expo run:ios --simulator",
    "web": "expo start --web",
    "prebuild": "expo prebuild",
    "prebuild:clean": "expo prebuild --clean",
    "clean:metro": "watchman watch-del-all && rm -rf $TMPDIR/metro-* && rm -rf $TMPDIR/haste-*",
    "clean:gradle": "cd android && ./gradlew clean",
    "clean:gradle:cache": "rm -rf android/.gradle android/build ~/.gradle/caches",
    "clean:android": "rm -rf android/.gradle android/build && cd android && ./gradlew clean",
    "clean:ios": "rm -rf ios/build && rm -rf ios/Pods && rm -rf ~/Library/Developer/Xcode/DerivedData",
    "clean:all": "yarn clean:metro && yarn clean:android && yarn clean:ios && rm -rf node_modules && yarn install",
    "pods": "cd ios && pod install && cd ..",
    "studio": "open -a 'Android Studio' android",
    "xcode": "open ios/*.xcworkspace",
    "devices:android": "adb devices",
    "devices:ios": "xcrun simctl list devices",
    "type-check": "tsc --noEmit"
  },
  "dependencies": {
    "@gorhom/bottom-sheet": "^5.2.8",
    "@tanstack/react-query": "^5.95.2",
    "expo": "~55.0.8",
    "expo-asset": "~55.0.10",
    "expo-audio": "~55.0.9",
    "expo-constants": "~55.0.9",
    "expo-dev-client": "~55.0.18",
    "expo-font": "~55.0.4",
    "expo-linking": "~55.0.8",
    "expo-router": "~55.0.7",
    "expo-status-bar": "~55.0.4",
    "expo-symbols": "~55.0.5",
    "expo-system-ui": "~55.0.10",
    "heroui-native": "^1.0.0",
    "react": "19.2.0",
    "react-dom": "19.2.0",
    "react-native": "0.83.2",
    "react-native-gesture-handler": "^2.30.0",
    "react-native-reanimated": "4.2.1",
    "react-native-safe-area-context": "5.6.2",
    "react-native-screens": "~4.23.0",
    "react-native-svg": "15.15.3",
    "react-native-worklets": "0.7.2",
    "tailwind-merge": "^3.5.0",
    "tailwind-variants": "^3.2.2",
    "tailwindcss": "^4.2.2",
    "uniwind": "^1.6.0",
    "zustand": "^5.0.12"
  },
  "devDependencies": {
    "@types/react": "~19.2.2",
    "typescript": "~5.9.2"
  },
  "private": true
}
